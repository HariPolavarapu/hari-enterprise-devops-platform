# Enterprise DevOps Platform - local environment template
# Copy this file to .env and update with your actual values

# Environment
ENVIRONMENT=development
COMPOSE_PROJECT_NAME=enterprise-platform

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=replace-locally
DB_NAME=platform_dev

# API Configuration
API_PORT=8080
API_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# JWT Configuration
JWT_SECRET_KEY=
JWT_ISSUER=enterprise-platform
JWT_AUDIENCE=enterprise-platform
JWT_EXPIRATION_MINUTES=60

# Email Configuration (for Notification Service)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Docker Registry (for production deployments)
DOCKER_REGISTRY=

# Kubernetes Configuration
KUBE_NAMESPACE=enterprise-platform
KUBE_ENVIRONMENT=dev

# AWS Configuration (if using AWS)
AWS_REGION=us-east-1
# Use an AWS profile or workload identity. Do not store access keys here.

# ArgoCD Configuration
ARGOCD_SERVER=
ARGOCD_TOKEN=
